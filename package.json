{
  "name": "open-design-canvas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @odc/api --filter @odc/web dev",
    "dev:api": "pnpm --filter @odc/api dev",
    "dev:web": "pnpm --filter @odc/web dev",
    "infra:up": "docker compose up -d postgres redis minio minio-init",
    "infra:down": "docker compose down",
    "db:migrate": "pnpm --filter @odc/db migrate",
    "build": "pnpm -r build",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "pnpm -r test",
    "test:e2e": "playwright test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "check:links": "node scripts/check-markdown-links.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "packageManager": "pnpm@9.15.9"
}
