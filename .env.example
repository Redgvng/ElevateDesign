NODE_ENV=development
PORT=3000

# Local tenant used until the authentication adapter is enabled.
DEFAULT_WORKSPACE_ID=ws_local
DEFAULT_WORKSPACE_NAME=Local Workspace
DEFAULT_WORKSPACE_SLUG=local

DATABASE_URL=postgresql://odc:odc_dev_password@127.0.0.1:5432/open_design_canvas
REDIS_URL=redis://127.0.0.1:6379
GENERATION_QUEUE_NAME=generation
GENERATION_JOB_LEASE_MS=120000
GENERATION_JOB_HEARTBEAT_MS=30000

OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_HEALTHCHECK_URL=http://127.0.0.1:9000/minio/health/ready
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=odc-artifacts
OBJECT_STORAGE_ACCESS_KEY=odc_minio
OBJECT_STORAGE_SECRET_KEY=odc_minio_password
OBJECT_STORAGE_FORCE_PATH_STYLE=true

AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Eve agent runtime (Phase 7). When enabled, generation jobs are dispatched to
# Eve (HTTP channel) instead of the legacy provider/worker path.
EVE_GENERATION_ENABLED=false
EVE_DISPATCH_URL=http://127.0.0.1:3100

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

POSTGRES_DB=open_design_canvas
POSTGRES_USER=odc
POSTGRES_PASSWORD=odc_dev_password
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_ROOT_USER=odc_minio
MINIO_ROOT_PASSWORD=odc_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
